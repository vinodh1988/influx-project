# Copy this file to .env and change secrets before running.

# Timezone
TZ=UTC

# InfluxDB setup
INFLUXDB_HTTP_PORT=8086
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=Password@12345
INFLUXDB_INIT_ORG=observability
INFLUXDB_INIT_BUCKET=telegraf_metrics
INFLUXDB_INIT_RETENTION=30d
INFLUXDB_INIT_ADMIN_TOKEN=ChangeMeInfluxAdminToken

# Telegraf identity tags
ENVIRONMENT=lab
ENGINE_HOST=local-docker
